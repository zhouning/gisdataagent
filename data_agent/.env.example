# ============================================================
# GIS Data Agent v4.0 — Environment Configuration Template
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# IMPORTANT:
#   - Do NOT use 'export' prefix (python-dotenv handles bare KEY=VALUE)
#   - Use forward slashes in Windows paths (D:/path/to/file)
#   - Do NOT commit .env to version control
# ============================================================

# ==========================
# REQUIRED: Database
# ==========================
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DATABASE=gis_agent
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_password

# ==========================
# REQUIRED: AI Model
# ==========================
# Option A: Vertex AI (recommended for production)
GOOGLE_GENAI_USE_VERTEXAI=TRUE
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-central1

# Option B: Google AI Studio API Key (simpler setup)
# GOOGLE_GENAI_USE_VERTEXAI=0
# GOOGLE_API_KEY=AIzaSy...your_api_key

# ==========================
# REQUIRED: Authentication
# ==========================
# Generate with: chainlit create-secret
CHAINLIT_AUTH_SECRET=your_random_secret_key_here

# ==========================
# OPTIONAL: OAuth2 Login
# ==========================
# Uncomment to enable "Sign in with Google" button
# OAUTH_GOOGLE_CLIENT_ID=your_google_client_id
# OAUTH_GOOGLE_CLIENT_SECRET=your_google_client_secret

# ==========================
# OPTIONAL: Agent Behavior
# ==========================
# Dynamic planner uses transfer_to_agent; false = fixed SequentialAgent pipelines
DYNAMIC_PLANNER=true

# ==========================
# OPTIONAL: Map Services
# ==========================
# Gaode Maps (高德) — geocoding & reverse geocoding
# GAODE_API_KEY=your_gaode_api_key

# Tianditu (天地图) — basemap tiles (Vec + Img)
# TIANDITU_TOKEN=your_tianditu_token

# ==========================
# OPTIONAL: Cloud Storage
# ==========================
# Huawei Cloud OBS (S3-compatible)
# HUAWEI_OBS_AK=your_access_key
# HUAWEI_OBS_SK=your_secret_key
# HUAWEI_OBS_SERVER=https://obs.cn-north-4.myhuaweicloud.com
# HUAWEI_OBS_BUCKET=your_bucket_name

# AWS S3
# AWS_ACCESS_KEY_ID=your_access_key
# AWS_SECRET_ACCESS_KEY=your_secret_key
# AWS_REGION=us-east-1
# AWS_S3_BUCKET=your_bucket_name

# Google Cloud Storage
# GCS_BUCKET=your_bucket_name

# ==========================
# OPTIONAL: Enterprise Bots
# ==========================
# WeChat Work (企业微信)
# WECOM_CORP_ID=your_corp_id
# WECOM_APP_SECRET=your_app_secret
# WECOM_TOKEN=your_callback_token
# WECOM_ENCODING_AES_KEY=your_aes_key
# WECOM_AGENT_ID=1000002
# WECOM_SHARE_BASE_URL=https://your-domain.com

# DingTalk (钉钉)
# DINGTALK_APP_KEY=your_app_key
# DINGTALK_APP_SECRET=your_app_secret
# DINGTALK_ROBOT_CODE=your_robot_code
# DINGTALK_SHARE_BASE_URL=https://your-domain.com

# Feishu / Lark (飞书)
# FEISHU_APP_ID=your_app_id
# FEISHU_APP_SECRET=your_app_secret
# FEISHU_VERIFICATION_TOKEN=your_verification_token
# FEISHU_ENCRYPT_KEY=your_encrypt_key
# FEISHU_SHARE_BASE_URL=https://your-domain.com

# ==========================
# OPTIONAL: Redis (Real-time Streams)
# ==========================
# Falls back to in-memory if not configured
# REDIS_URL=redis://localhost:6379/0

# ==========================
# OPTIONAL: Observability
# ==========================
# LOG_LEVEL=INFO
# LOG_FORMAT=text
# AUDIT_LOG_RETENTION_DAYS=90

# ==========================
# OPTIONAL: Usage Limits
# ==========================
# DAILY_ANALYSIS_LIMIT=20
# MONTHLY_TOKEN_LIMIT=0

# ==========================
# OPTIONAL: Extensions
# ==========================
# ArcPy Integration (use forward slashes!)
# ARCPY_PYTHON_EXE=D:/path/to/arcgis/python.exe

# MCP Toolbox
# MCP_TOOLBOX_URL=http://localhost:8080

# Google Earth Engine
# GEE_SERVICE_ACCOUNT_KEY=path/to/key.json
