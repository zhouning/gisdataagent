# =============================================================================
# GIS Data Agent — Environment Variables
# Copy this file to data_agent/.env and fill in your values.
# Lines use 'export' prefix (bash-style) for compatibility.
# =============================================================================

# --- PostgreSQL / PostGIS (required) -----------------------------------------
export POSTGRES_HOST="db"                    # Docker service name or external host
export POSTGRES_PORT="5432"
export POSTGRES_DATABASE="gis_agent"
export POSTGRES_USER="agent_user"
export POSTGRES_PASSWORD="change_me_strong_password"

# Admin credentials for running migrations (only needed in entrypoint)
# POSTGRES_ADMIN_USER="postgres"
# POSTGRES_ADMIN_PASSWORD="postgres"

# --- Google AI (required — choose one method) --------------------------------
# Method 1: API Key (simpler)
# GOOGLE_API_KEY=your_google_api_key

# Method 2: Vertex AI (enterprise)
GOOGLE_GENAI_USE_VERTEXAI=TRUE
GOOGLE_CLOUD_PROJECT=your_project_id
GOOGLE_CLOUD_LOCATION=global
# Mount service account JSON to /app/secrets/service-account.json
# GOOGLE_APPLICATION_CREDENTIALS=/app/secrets/service-account.json

# --- Gaode Maps API (required for geocoding, POI, admin boundary) ------------
export GAODE_API_KEY=your_gaode_api_key

# --- Chainlit Authentication (required) --------------------------------------
# Generate with: chainlit create-secret
CHAINLIT_AUTH_SECRET="generate_a_random_secret_here"

# --- Google OAuth2 (optional) ------------------------------------------------
# OAUTH_GOOGLE_CLIENT_ID=your_google_client_id
# OAUTH_GOOGLE_CLIENT_SECRET=your_google_client_secret

# --- Huawei Cloud OBS (optional — cloud file storage) ------------------------
# export HUAWEI_OBS_AK="your_access_key"
# export HUAWEI_OBS_SK="your_secret_key"
# export HUAWEI_OBS_SERVER="https://obs.cn-north-4.myhuaweicloud.com"
# export HUAWEI_OBS_BUCKET="your_bucket_name"

# --- Tianditu Basemap (optional) ---------------------------------------------
# TIANDITU_TOKEN=your_tianditu_token

# --- Dynamic Planner (default: true) -----------------------------------------
export DYNAMIC_PLANNER=true

# --- Usage Limits (optional) -------------------------------------------------
# DAILY_ANALYSIS_LIMIT=20          # Max analyses per user per day (0=unlimited, admin exempt)
# MONTHLY_TOKEN_LIMIT=0            # Max tokens per user per month (0=unlimited)

# --- Audit Log Retention (optional) ------------------------------------------
# AUDIT_LOG_RETENTION_DAYS=90

# --- ArcPy (not available in Docker — graceful degradation) ------------------
# ARCPY_PYTHON_EXE is intentionally not set in Docker

# --- Enterprise WeChat Bot (optional — PRD F7) ------------------------------
# Create a self-built app in WeCom admin (应用管理 → 自建应用)
# WECOM_CORP_ID=your_corp_id                    # 企业ID
# WECOM_APP_SECRET=your_app_secret              # 应用Secret
# WECOM_TOKEN=your_callback_token               # 接收消息 → Token
# WECOM_ENCODING_AES_KEY=your_43char_key        # 接收消息 → EncodingAESKey
# WECOM_AGENT_ID=1000002                        # 应用AgentId
# WECOM_SHARE_BASE_URL=https://gis.example.com  # Share link base URL (optional)
